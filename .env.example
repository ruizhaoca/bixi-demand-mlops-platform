AWS_REGION=us-east-2
S3_BUCKET=insy684

# Use local for laptop development. Use s3 on EC2 after the IAM role is attached.
MODEL_SOURCE=local

# Required only when MODEL_SOURCE=s3.
MODEL_KEY=bixi-models/model_lightgbm.txt
META_KEY=bixi-models/meta_lightgbm.pkl

# Optional local overrides.
LOCAL_MODEL_PATH=model_lightgbm.txt
LOCAL_META_PATH=meta_lightgbm.pkl

# FastAPI-backed Streamlit UI (EC2 -> App Runner).
BIXI_API_URL=https://example.us-east-2.awsapprunner.com
BIXI_API_TIMEOUT=30
# Store the real value in Secrets Manager / the EC2 shell, never in git.
BIXI_API_KEY=
